#include <stdio.h>

int main() {
    int precos[] = {70, 20, 45, 55, 75};
    int tamanho = 5;
    int alvo = 100;

    int i, j;
    int encontrou = 0;

    for(i = 0; i < tamanho; i++) {
        for(j = i + 1; j < tamanho; j++) {
            if(precos[i] + precos[j] == alvo) {
                printf("Indices encontrados: [%d, %d]\n", i, j);
                encontrou = 1;
                break;
            }
        }
        if(encontrou) break;
    }

    if(!encontrou) {
        printf("Nenhum par encontrado.\n");
    }

    return 0;
}
