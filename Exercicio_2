#include <stdio.h>

int main() {
    int reproducoes[] = {70, 30, 120, 100, 50, 60};
    int tamanho = 6;

    int maiorSoma = 0;
    int i;

    for(i = 0; i < tamanho - 1; i++) {
        int soma = reproducoes[i] + reproducoes[i + 1];

        if(soma > maiorSoma) {
            maiorSoma = soma;
        }
    }

    printf("Maior soma consecutivas: %d\n", maiorSoma);

    return 0;
}
